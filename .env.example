# =============================================================
# Adra-AI — Production Environment Variables
# Copy this file to .env on your Droplet and fill in real values.
# NEVER commit .env to git.
# =============================================================

# ----- Database -----
# On the Droplet with Docker Compose, use the service name "postgres"
DATABASE_URL=postgresql+asyncpg://adrai:CHANGE_THIS_STRONG_PASSWORD@postgres:5432/adrai
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# ----- Qdrant Vector DB -----
# Docker service name is "qdrant"
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# ----- Security -----
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_64_CHAR_HEX_STRING

# ----- Google OAuth -----
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret

# ----- GitHub OAuth -----
GITHUB_OAUTH_CLIENT_ID=your-github-oauth-client-id
GITHUB_OAUTH_CLIENT_SECRET=your-github-oauth-client-secret

# ----- URLs -----
# FRONTEND_URL: your Vercel deployment URL (used for CORS and OAuth redirects)
FRONTEND_URL=https://your-app.vercel.app
# NEXT_PUBLIC_API_URL: the Droplet's public IP or domain (used by the frontend)
NEXT_PUBLIC_API_URL=http://YOUR_DROPLET_IP

# ----- Frontend OAuth (used by Vercel, not the backend) -----
NEXT_PUBLIC_GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id
NEXT_PUBLIC_GITHUB_OAUTH_CLIENT_ID=your-github-oauth-client-id

# ----- LLM / AI -----
GROQ_API_KEY=your-groq-api-key
GOOGLE_API_KEY=your-google-api-key

# ----- Rate limit tuning -----
LLM_MIN_INTERVAL_SEC=2.5
LLM_MAX_RETRIES=5
LLM_MAX_CONTENT_CHARS=10000

# ----- Admin Access -----
# Comma-separated list of emails that bypass usage quotas
ADMIN_EMAILS=admin@example.com

# ----- LangSmith (optional — for tracing/debugging) -----
# LANGSMITH_TRACING_V2=true
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LANGSMITH_API_KEY=your-langsmith-api-key
# LANGSMITH_PROJECT=Adra AI
