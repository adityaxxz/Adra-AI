# ==========================================
# Adra-AI Monorepo Gitignore Configuration
# ==========================================

# --- System & IDE Files ---
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
*.swp
*.swo
*.bak
*.tmp
*.orig

# --- Project Documentation & Scratch Files ---
# (Keeping project design/deployment docs untracked as per configuration)
adraai.md
DEPLOYMENT.md
ARCHITECTURE_DECISIONS.md
IMPLEMENTATION_SUMMARY.md
g.ipynb
test.py
notes.md
cmds.txt
agent/repository/test.py
cmds_for_droplets
CLAUDE.md
backend/backend_impl.md


# --- Environment Variables & Secrets ---
.env
.env.*
!.env.example
secrets/
credentials.json
service-account.json

# --- Runtime Data Directories ---
# Keep local uploads, temp checkouts, and vector storage ignored
temp_repos/
uploaded_repos/
chroma_db/
qdrant_storage/
chroma/
chromadb/
vector_store/
faiss_index/
uploads/
documents/
storage/
data/

# --- Generated Code & Projects ---
# Ignore workspace-generated output project folders
generated_projects/
generated_project/
generated_project_tic_tac_toe/
generated_project_blog_api_using_fastapi_and_sqlite/

# --- Python / FastAPI (Backend & Agent) ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
downloads/
eggs/
.eggs/
# Anchored paths to avoid ignoring subdirectories like frontend/lib
/lib/
/lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/
.venv/
venv/
env/
ENV/
*.db
*.sqlite
*.sqlite3
.ipynb_checkpoints/

# --- Node / Next.js (Frontend) ---
node_modules/
.next/
out/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.turbo/
.vercel/
*.tsbuildinfo

# --- AI Models / Large Checkpoints ---
models/
checkpoints/
weights/
*.pt
*.pth
*.bin
*.gguf
*.safetensors

# --- Docker & CI/CD ---
.docker/
.langsmith/
coverage/
coverage.xml